{
  "html_rules": [
    {
      "id": "HTML001",
      "name": "Add coras-theme attribute to body tag",
      "enabled": true,
      "description": "v9.0.1 introduces Dark and Light theme support. The default theme must be declared on the <body> element in index.html. Without this attribute the application will have no theme applied.",
      "detect_pattern": "<body",
      "ai_instruction": "Locate the <body> tag in src/index.html. If it does not already have a coras-theme attribute, add coras-theme='light' as the default. If coras-theme already exists with any value, do NOT overwrite it — add a warning comment above the tag: <!-- WARNING: coras-theme already set, verify this is the intended theme for v9.0.1 --> and leave the value unchanged.",
      "example_before": "<body>\n  <app-root></app-root>\n</body>",
      "example_after": "<body coras-theme=\"light\">\n  <app-root></app-root>\n</body>"
    }
  ],

  "package_rules": [
    {
      "id": "PKG001",
      "name": "Update @frmk2sjs/services to 9.0.1",
      "enabled": true,
      "description": "Core Coras services package must be updated to 9.0.1 as part of this release.",
      "detect_pattern": "@frmk2sjs/services",
      "ai_instruction": "In package.json, find the @frmk2sjs/services dependency. Update its version to exactly '9.0.1'. Do not change any other dependency. Do not change the key name.",
      "example_before": "\"@frmk2sjs/services\": \"8.0.6\"",
      "example_after": "\"@frmk2sjs/services\": \"9.0.1\""
    },
    {
